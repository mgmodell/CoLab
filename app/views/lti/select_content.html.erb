<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>CoLab – Select Activity to Link</title>
  <style>
    body { font-family: sans-serif; max-width: 900px; margin: 2rem auto; padding: 0 1rem; }
    h1   { font-size: 1.4rem; margin-bottom: 1rem; }
    h2   { font-size: 1.1rem; margin-top: 1.5rem; }
    table { width: 100%; border-collapse: collapse; margin-bottom: 1rem; }
    th, td { text-align: left; padding: 0.5rem 0.75rem; border-bottom: 1px solid #ddd; }
    th { background: #f5f5f5; }
    button.select-btn {
      background: #1565c0; color: #fff; border: none;
      padding: 0.4rem 1rem; border-radius: 4px; cursor: pointer;
    }
    button.select-btn:hover { background: #0d47a1; }
    .no-activities { color: #888; font-style: italic; }
  </style>
</head>
<body>
  <h1>Select a CoLab Activity to Link in Moodle</h1>
  <p>
    Choose an activity below. Moodle will create a direct link to it in your
    course, and a gradebook column will be added where applicable.
  </p>

  <% if @courses.empty? %>
    <p class="no-activities" id="no-courses">
      No courses are available. Make sure you are an instructor in at least one
      CoLab course.
    </p>
  <% else %>
    <% @courses.each do |course| %>
      <h2><%= course.get_name(false) %></h2>

      <%# ── Bingo! games ──────────────────────────────────────────────── %>
      <% if course.bingo_games.any? %>
        <table id="bingo-games-<%= course.id %>">
          <thead>
            <tr>
              <th>Terms List (Bingo! Game)</th>
              <th>Type</th>
              <th>Action</th>
            </tr>
          </thead>
          <tbody>
            <% course.bingo_games.each do |bingo| %>
              <tr>
                <td><%= bingo.get_topic(false) %></td>
                <td>Bingo! / Terms List</td>
                <td>
                  <%= form_tag lti_deep_link_response_path, method: :post,
                                                            id: "dl-form-bingo-#{bingo.id}" do %>
                    <%= hidden_field_tag :activity_type, 'bingo_game' %>
                    <%= hidden_field_tag :activity_id,   bingo.id %>
                    <button type="submit" class="select-btn"
                            aria-label="Select <%= bingo.get_topic(false) %>">
                      Select
                    </button>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% end %>

      <%# ── Projects ─────────────────────────────────────────────────── %>
      <% if course.projects.any? %>
        <table id="projects-<%= course.id %>">
          <thead>
            <tr>
              <th>Project</th>
              <th>Type</th>
              <th>Action</th>
            </tr>
          </thead>
          <tbody>
            <% course.projects.each do |project| %>
              <tr>
                <td><%= project.get_name(false) %></td>
                <td>Project</td>
                <td>
                  <%= form_tag lti_deep_link_response_path, method: :post,
                                                            id: "dl-form-project-#{project.id}" do %>
                    <%= hidden_field_tag :activity_type, 'project' %>
                    <%= hidden_field_tag :activity_id,   project.id %>
                    <button type="submit" class="select-btn"
                            aria-label="Select <%= project.get_name(false) %>">
                      Select
                    </button>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% end %>

      <%# ── Experiences ───────────────────────────────────────────────── %>
      <% if course.experiences.any? %>
        <table id="experiences-<%= course.id %>">
          <thead>
            <tr>
              <th>Experience</th>
              <th>Type</th>
              <th>Action</th>
            </tr>
          </thead>
          <tbody>
            <% course.experiences.each do |experience| %>
              <tr>
                <td><%= experience.get_name(false) %></td>
                <td>Experience</td>
                <td>
                  <%= form_tag lti_deep_link_response_path, method: :post,
                                                            id: "dl-form-experience-#{experience.id}" do %>
                    <%= hidden_field_tag :activity_type, 'experience' %>
                    <%= hidden_field_tag :activity_id,   experience.id %>
                    <button type="submit" class="select-btn"
                            aria-label="Select <%= experience.get_name(false) %>">
                      Select
                    </button>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% end %>

      <% if course.bingo_games.empty? && course.projects.empty? && course.experiences.empty? %>
        <p class="no-activities">No activities in this course yet.</p>
      <% end %>
    <% end %>
  <% end %>
</body>
</html>
