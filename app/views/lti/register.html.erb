<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title><%= t '.title' %></title>
  <style>
    body { font-family: sans-serif; max-width: 600px; margin: 60px auto; padding: 0 20px; color: #333; }
    .success { border-left: 4px solid #4caf50; padding: 12px 16px; background: #f1f8f1; }
    .error   { border-left: 4px solid #f44336; padding: 12px 16px; background: #fdf1f1; }
    .detail  { margin-top: 16px; font-size: 0.9em; color: #555; }
    .instructions { margin-top: 2rem; }
    .instructions h2 { font-size: 1.1rem; margin-bottom: 0.5rem; }
    code     { background: #eee; padding: 2px 5px; border-radius: 3px; }
    ol { padding-left: 1.4rem; line-height: 1.8; }
  </style>
</head>
<body>
  <h1><%= t '.heading' %></h1>

  <% if @registration_error.present? %>
    <div class="error">
      <strong><%= t '.error_heading' %></strong> <%= @registration_error %>
    </div>
    <p class="detail"><%= t '.error_detail' %></p>
  <% elsif @client_id.present? %>
    <div class="success">
      <strong><%= t '.success_heading' %></strong>
      <%= t '.success_body' %>
    </div>
    <p class="detail">
      <% if @platform_issuer.present? %>
        <%= t '.platform_label' %> <code><%= @platform_issuer %></code><br>
      <% end %>
      <%= t '.client_id_label' %> <code><%= @client_id %></code><br>
      <%= t '.close_tab' %>
    </p>
  <% else %>
    <div class="success">
      <strong><%= t '.config_only_heading' %></strong>
      <% if @platform_issuer.blank? %>
        <%= t '.config_only_no_platform' %>
      <% else %>
        <%= t '.config_only_no_endpoint' %>
      <% end %>
    </div>
  <% end %>

  <div class="instructions">
    <h2><%= t '.generic_instructions_heading' %></h2>
    <%= sanitize t('.generic_instructions_html'), tags: %w[ol li strong em code] %>
  </div>
</body>
</html>
