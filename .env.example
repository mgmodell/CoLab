# .env.example
# Copy this file to .env (which is gitignored) and fill in your own values.
#
# CUCUMBER_PUBLISH_TOKEN
#   Enables publishing test results to Cucumber Cloud (https://cucumber.io/docs/cucumber/reporting/).
#   Obtain a token from your Cucumber Cloud project settings.
#   If unset, Cucumber Cloud reporting is silently disabled — tests still run normally.
CUCUMBER_PUBLISH_TOKEN=your-cucumber-cloud-token-here
