#!/usr/bin/env ruby
# frozen_string_literal: true

require "rbconfig"

# Returns truthy when overmind should be skipped:
#   1. Native Windows shell (MSYS2/Git Bash/Cygwin) — host_os matches mswin/mingw/cygwin
#   2. Inside a container hosted on Windows (Podman/Docker) — filesystem type is v9fs
# WSL reports a linux host_os and uses a normal ext4/overlay filesystem, so it
# continues to use overmind.
def skip_overmind?
  return true if RbConfig::CONFIG["host_os"] =~ /mswin|mingw|cygwin/i

  fs_type = `stat -f -c %T . 2>/dev/null`.strip rescue ""
  fs_type == "v9fs"
end

def installed?(process)
  IO.popen "#{process} -v"
rescue Errno::ENOENT
  false
end

def run(process)
  system "#{process} start -f Procfile.dev-static"
rescue Errno::ENOENT
  warn <<~MSG
    ERROR:
    Please ensure `Procfile.dev-static` exists in your project!
  MSG
  exit!
end

if !skip_overmind? && installed?("overmind")
  run "overmind"
elsif installed? "foreman"
  run "foreman"
else
  warn <<~MSG
    NOTICE:
    For this script to run, you need 'overmind' or 'foreman' installed on your machine.
    Please install one and try again:
      overmind: https://github.com/DarthSim/overmind
      foreman:  gem install foreman
  MSG
  exit!
end
