// CoLab Security (penetration-testing) dev container.
// For format details, see https://aka.ms/devcontainer.json
//
// This is an ADDITIONAL dev container alongside the main "CoLab" dev container.
// In VS Code: Command Palette -> "Dev Containers: Reopen in Container" and pick
// "CoLab Security (Pentest)". VS Code brings up the whole security stack
// (app + db + redis + pentest) and attaches your editor + terminal to the Kali
// toolbox (zsh + oh-my-zsh, every tool preinstalled). The CoLab production
// target is reachable from the toolbox at http://app:3000 and from your host
// browser at http://localhost:13000.
//
// Cross-platform: this is a standard compose-based dev container (same model as
// the main one) and works on macOS, Linux, and Windows. No per-OS override is
// needed here — the toolbox runs as root, mounts the source read-only, and keeps
// its notes in a named volume, so the UID-remapping concerns that the main dev
// container handles do not apply.
{
	"name": "CoLab Security (Pentest)",
	"dockerComposeFile": "../../containers/sec_env/docker-compose.yml",
	"service": "pentest",
	// Bring the rest of the engagement stack up with the toolbox.
	"runServices": ["app", "db", "redis"],
	// Open the operator workspace (engagement notes/evidence; persisted in a
	// named volume). The read-only CoLab source is available at /opt/colab-src.
	"workspaceFolder": "/root/engagement",
	"remoteUser": "root",
	"updateRemoteUserUID": false,
	// Keep the image's CMD (sleep infinity) instead of letting VS Code override it.
	"overrideCommand": false,
	// Stop the whole stack when you close the window.
	"shutdownAction": "stopCompose",

	// On first creation, fetch the latest nuclei templates so the first scan is
	// ready and current. Non-fatal: an offline/first-open hiccup won't block the
	// container (nuclei also auto-updates on its first run).
	"postCreateCommand": "nuclei -ut || true",

	"customizations": {
		"vscode": {
			"settings": {
				"terminal.integrated.defaultProfile.linux": "zsh"
			},
			"extensions": [
				"timonwong.shellcheck",
				"yzhang.markdown-all-in-one"
			]
		}
	}
}
